{
  "name": "action-plan-diff-skill",
  "version": "0.1.0",
  "description": "Compare dry-run action plans with execution traces and report approval drift.",
  "type": "module",
  "bin": {
    "action-plan-diff-skill": "./src/cli.js"
  },
  "scripts": {
    "test": "node --test",
    "check": "node --check src/*.js test/*.js",
    "lint": "npm run check",
    "build": "node scripts/build-check.js",
    "smoke": "node src/cli.js --help && node src/cli.js fixtures/sample.jsonl --format markdown",
    "package:smoke": "node scripts/verify-package-bin.mjs && npm pack --dry-run",
    "release:check": "npm run lint && npm test && npm run build && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "agent",
    "skill",
    "audit",
    "dry-run",
    "cli"
  ],
  "files": [
    "src",
    "fixtures",
    "scripts",
    "docs",
    "SKILL.md",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/action-plan-diff-skill.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/action-plan-diff-skill/issues"
  },
  "homepage": "https://github.com/rogerchappel/action-plan-diff-skill#readme",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  }
}
